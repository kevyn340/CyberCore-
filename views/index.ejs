<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CyberCore Bot</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <section class="hero">
        <div class="hero-content">
            <div class="glitch-wrapper">
                <h1 class="glitch" data-text="CyberCore">CyberCore</h1>
            </div>
            <p class="hero-subtitle">O bot Discord mais completo para gerenciar seu servidor com estilo futurista</p>
            <div class="hero-buttons">
                <a href="/auth/discord" class="btn btn-primary">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057.101 18.08.114 18.102.138 18.116a19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028 14.09 14.09 0 0 0 1.226-1.994.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
                    Login com Discord
                </a>
                <a href="https://discord.com/api/oauth2/authorize?client_id=<%= process.env.CLIENT_ID %>&permissions=8&scope=bot%20applications.commands" class="btn btn-outline" target="_blank">
                    Adicionar ao Servidor
                </a>
            </div>
        </div>
        <div class="hero-grid"></div>
    </section>

    <section class="features">
        <div class="container">
            <h2 class="section-title">Funcionalidades</h2>
            <div class="features-grid">
                <div class="feature-card">
                    <div class="feature-icon">🎫</div>
                    <h3>Sistema de Tickets</h3>
                    <p>Painel profissional com 5 categorias, prioridades, transcripts e anti-duplicata.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">⚖️</div>
                    <h3>Moderação</h3>
                    <p>Ban, kick, mute, warn e clear com logs completos e notificações por DM.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">📊</div>
                    <h3>Estatísticas</h3>
                    <p>Acompanhe tickets abertos, membros atendidos e ações de moderação.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">📝</div>
                    <h3>Logs Completos</h3>
                    <p>Logs de mensagens, membros, tickets e punições em tempo real.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🔒</div>
                    <h3>Segurança</h3>
                    <p>Anti-spam, cooldowns, verificação de permissões e tratamento de erros.</p>
                </div>
                <div class="feature-card">
                    <div class="feature-icon">🌐</div>
                    <h3>Dashboard Web</h3>
                    <p>Gerencie seu bot diretamente pelo navegador com login Discord OAuth2.</p>
                </div>
            </div>
        </div>
    </section>

    <%- include('partials/footer') %>
    <script src="/js/main.js"></script>
</body>
</html>
